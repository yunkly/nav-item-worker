{
  "name": "nav-item-backend",
  "version": "1.0.0",
  "author": "eooce",
  "description": "nav-item-backend",
  "repository": "https://github.com/eooce/nav-item",
  "license": "MIT",
  "main": "app.js",
  "scripts": {
    "dev": "node app.js",
    "start": "node app.js",
    "dev:worker": "node scripts/run-wrangler.js dev --local",
    "deploy:worker": "node scripts/run-wrangler.js deploy",
    "d1:apply:local": "node scripts/run-wrangler.js d1 migrations apply nav-item --local",
    "d1:apply:remote": "node scripts/run-wrangler.js d1 migrations apply nav-item --remote",
    "build:web": "npm run build --prefix web",
    "deploy": "npm run build:web && npm run deploy:worker"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "jose": "^5.9.2"
  },
  "devDependencies": {
    "wrangler": "^3.94.0"
  },
  "engines": {
    "node": ">=14"
  }
}
